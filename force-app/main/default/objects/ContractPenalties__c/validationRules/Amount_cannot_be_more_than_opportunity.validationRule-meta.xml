<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Amount_cannot_be_more_than_opportunity</fullName>
    <active>true</active>
    <errorConditionFormula>(Financial_Amount_of_Penalty__c &gt;  Opportunity__r.Amount ) ||  ISBLANK(Opportunity__r.Amount)</errorConditionFormula>
    <errorDisplayField>Financial_Amount_of_Penalty__c</errorDisplayField>
    <errorMessage>The Financial Penalty cannot be higher value than the original opportunity.</errorMessage>
</ValidationRule>
