    <description>Whenever Account&apos;s billing address is changed OR a new Account record with Billing address is created, It updates Shipping address with the same Billing Address</description>
    <formulas>
        <processMetadataValues>
            <name>originalFormula</name>
            <value>
                <stringValue>( ( NOT(ISNULL([Account].BillingCity ) )  || NOT(ISNULL([Account].BillingCountry ) ) || NOT(ISNULL([Account].BillingState ) ) || NOT(ISNULL([Account].BillingStreet ) ) || NOT(ISNULL([Account].BillingPostalCode ) ) || NOT(ISNULL([Account].BillingLatitude ) ) || NOT(ISNULL([Account].BillingLongitude ) ) ) &amp;&amp; ISNEW() ) || ( ISCHANGED([Account].BillingCity )  || ISCHANGED([Account].BillingCountry ) || ISCHANGED([Account].BillingState ) || ISCHANGED([Account].BillingStreet ) || ISCHANGED([Account].BillingPostalCode ) || ISCHANGED([Account].BillingLatitude ) || ISCHANGED([Account].BillingLongitude ) )</stringValue>
            </value>
        </processMetadataValues>
        <name>formula_myRule_1</name>
        <dataType>Boolean</dataType>
        <expression>( ( NOT(ISNULL({!myVariable_current.BillingCity} ) )  || NOT(ISNULL({!myVariable_current.BillingCountry} ) ) || NOT(ISNULL({!myVariable_current.BillingState} ) ) || NOT(ISNULL({!myVariable_current.BillingStreet} ) ) || NOT(ISNULL({!myVariable_current.BillingPostalCode} ) ) || NOT(ISNULL({!myVariable_current.BillingLatitude} ) ) || NOT(ISNULL({!myVariable_current.BillingLongitude} ) ) ) &amp;&amp; ISNEW() ) || ( ISCHANGED({!myVariable_current.BillingCity} )  || ISCHANGED({!myVariable_current.BillingCountry} ) || ISCHANGED({!myVariable_current.BillingState} ) || ISCHANGED({!myVariable_current.BillingStreet} ) || ISCHANGED({!myVariable_current.BillingPostalCode} ) || ISCHANGED({!myVariable_current.BillingLatitude} ) || ISCHANGED({!myVariable_current.BillingLongitude} ) )</expression>
    </formulas>
