    <loops>
        <name>for_each_Account</name>
        <label>for each Account</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <collectionReference>Get_Linked_Accounts</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>Reset_Account_values</targetReference>
        </nextValueConnector>
        <noMoreValuesConnector>
            <targetReference>Update_Account_Totals</targetReference>
        </noMoreValuesConnector>
    </loops>
    <loops>
        <name>Get_AccountIds</name>
        <label>Get AccountIds</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <collectionReference>Get_Active_Contracts</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>Add_Account_ID_to_collection</targetReference>
        </nextValueConnector>
        <noMoreValuesConnector>
            <targetReference>Get_Linked_Accounts</targetReference>
        </noMoreValuesConnector>
    </loops>
    <processMetadataValues>
