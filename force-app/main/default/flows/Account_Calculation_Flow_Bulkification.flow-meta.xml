    </decisions>
    <decisions>
        <description>Now based on the contract&apos;s sector - add the total</description>
        <name>Sectors</name>
        <label>Sectors</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Calculate_Contract_Totals</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Drivetech</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Calculate_Contract_Totals.Sector__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Drivetech</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_Drivetech_total</targetReference>
            </connector>
            <label>Drivetech</label>
        </rules>
        <rules>
            <name>Accident_Management</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Calculate_Contract_Totals.Sector__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Accident Management</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_Accident_total</targetReference>
            </connector>
            <label>Accident Management</label>
        </rules>
        <rules>
            <name>Roadside</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>Calculate_Contract_Totals.Sector__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>OEM</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Calculate_Contract_Totals.Sector__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Fleet &amp; Leasing</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Calculate_Contract_Totals.Sector__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>FI&amp;P</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_Roadside_value</targetReference>
            </connector>
            <label>Roadside</label>
        </rules>
        <rules>
            <name>Vixa_Pro</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Calculate_Contract_Totals.Sector__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>AAX</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_Vixa_Pro_Contract_Value</targetReference>
            </connector>
            <label>Vixa Pro</label>
        </rules>
        <rules>
            <name>Commissioning_Force</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Calculate_Contract_Totals.Sector__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Commissioning Force</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_Commissioning_Force_Contract_Value</targetReference>
            </connector>
            <label>Commissioning Force</label>
        </rules>
        <rules>
            <name>SMR</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Calculate_Contract_Totals.Sector__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Prestige</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_SMR_Contract_Value</targetReference>
            </connector>
            <label>SMR</label>
        </rules>
    </decisions>
    <environments>Default</environments>
    <formulas>
        <name>FxAccidentContractTotal</name>
        <dataType>Currency</dataType>
        <expression>{!Calculate_Contract_Totals.Annual_Contract_Value_text__c}*{!Calculate_Contract_Totals.ContractTerm}</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <name>FxDrivetechContractTotal</name>
        <dataType>Currency</dataType>
        <expression>IF( 
!ISBLANK({!Calculate_Contract_Totals.Annual_Contract_Value_text__c}), 
{!Calculate_Contract_Totals.Annual_Contract_Value_text__c}*{!Calculate_Contract_Totals.ContractTerm}, 
0)</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <name>FxPoliceForceContractTotal</name>
