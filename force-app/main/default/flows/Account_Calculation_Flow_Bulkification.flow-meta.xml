        <expression>{!Calculate_Contract_Totals.Annual_Contract_Value_text__c}*{!Calculate_Contract_Totals.ContractTerm}</expression>
        <scale>2</scale>
    </formulas>
    <interviewLabel>Account Calculation Flow - Bulkification {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Account Calculation Flow - Active Contracts</label>
    <loops>
        <name>Calculate_Contract_Totals</name>
        <label>Calculate Totals</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <collectionReference>Filter_Contracts_for_this_Account</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
