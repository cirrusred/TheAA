        <scale>2</scale>
    </formulas>
    <formulas>
        <name>fxToday</name>
        <dataType>Date</dataType>
        <expression>TODAY()</expression>
    </formulas>
    <formulas>
        <name>FxTotalContractValue</name>
        <dataType>Currency</dataType>
        <expression>{!Calculate_Contract_Totals.Annual_Contract_Value_text__c}*{!Calculate_Contract_Totals.ContractTerm}</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
